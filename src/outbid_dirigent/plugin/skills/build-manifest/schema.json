{
  "$defs": {
    "Component": {
      "properties": {
        "name": {
          "default": "",
          "title": "Name",
          "type": "string"
        },
        "type": {
          "default": "",
          "title": "Type",
          "type": "string",
          "description": "database, cache, queue, external, backend, frontend, worker"
        },
        "runtime": {
          "default": "",
          "title": "Runtime",
          "type": "string",
          "description": "docker-compose, process"
        },
        "start": {
          "anyOf": [
            {
              "$ref": "#/$defs/ComponentStart"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "start_cmd": {
          "default": "",
          "title": "Start Cmd",
          "type": "string",
          "description": "Legacy flat field \u2014 prefer start.command"
        },
        "stop_cmd": {
          "default": "",
          "title": "Stop Cmd",
          "type": "string"
        },
        "ready_check": {
          "default": "",
          "title": "Ready Check",
          "type": "string",
          "description": "Legacy flat field \u2014 prefer start.ready_check"
        },
        "ready_timeout": {
          "default": 30,
          "title": "Ready Timeout",
          "type": "integer"
        },
        "endpoint": {
          "anyOf": [
            {
              "$ref": "#/$defs/Endpoint"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "mock": {
          "anyOf": [
            {
              "$ref": "#/$defs/MockConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "If set, component is auto-mocked in tests (no real service needed)"
        },
        "depends_on": {
          "items": {
            "type": "string"
          },
          "title": "Depends On",
          "type": "array"
        }
      },
      "title": "Component",
      "type": "object"
    },
    "ComponentStart": {
      "properties": {
        "command": {
          "default": "",
          "title": "Command",
          "type": "string"
        },
        "working_dir": {
          "default": "",
          "title": "Working Dir",
          "type": "string"
        },
        "env": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Env",
          "type": "object"
        },
        "ready_check": {
          "$ref": "#/$defs/ReadyCheck"
        }
      },
      "title": "ComponentStart",
      "type": "object"
    },
    "Endpoint": {
      "properties": {
        "host": {
          "default": "localhost",
          "title": "Host",
          "type": "string"
        },
        "port": {
          "default": 0,
          "title": "Port",
          "type": "integer"
        },
        "protocol": {
          "default": "tcp",
          "title": "Protocol",
          "type": "string"
        }
      },
      "title": "Endpoint",
      "type": "object"
    },
    "EnvVar": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "source": {
          "default": "",
          "title": "Source",
          "type": "string",
          "description": "Where this env var comes from (e.g. 'Doppler', '.env')"
        },
        "secret": {
          "default": false,
          "title": "Secret",
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "title": "EnvVar",
      "type": "object"
    },
    "Gap": {
      "properties": {
        "area": {
          "default": "",
          "title": "Area",
          "type": "string",
          "description": "e.g. E2E/Playwright, Load testing"
        },
        "reason": {
          "default": "",
          "title": "Reason",
          "type": "string",
          "description": "e.g. not_configured, requires_hardware"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "mitigation": {
          "default": "",
          "title": "Mitigation",
          "type": "string"
        },
        "risk": {
          "default": "medium",
          "title": "Risk",
          "type": "string",
          "description": "low, medium, high",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      },
      "title": "Gap",
      "type": "object",
      "description": "A known gap in test coverage"
    },
    "MockConfig": {
      "properties": {
        "strategy": {
          "default": "stub",
          "title": "Strategy",
          "type": "string",
          "description": "stub, record, passthrough"
        },
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        }
      },
      "title": "MockConfig",
      "type": "object"
    },
    "Prerequisite": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "check": {
          "title": "Check",
          "type": "string",
          "description": "Shell command that proves the tool is installed"
        },
        "setup_command": {
          "default": "",
          "title": "Setup Command",
          "type": "string",
          "description": "Optional auto-install command"
        },
        "manual": {
          "default": false,
          "title": "Manual",
          "type": "boolean",
          "description": "If true, skip automated check"
        },
        "install_hint": {
          "default": "",
          "title": "Install Hint",
          "type": "string",
          "description": "Human-readable install instructions"
        },
        "required_version": {
          "default": "",
          "title": "Required Version",
          "type": "string",
          "description": "e.g. >=3.10"
        }
      },
      "required": [
        "name",
        "check"
      ],
      "title": "Prerequisite",
      "type": "object"
    },
    "Prerequisites": {
      "properties": {
        "tools": {
          "items": {
            "$ref": "#/$defs/Prerequisite"
          },
          "title": "Tools",
          "type": "array"
        },
        "env_vars": {
          "items": {
            "$ref": "#/$defs/EnvVar"
          },
          "title": "Env Vars",
          "type": "array"
        }
      },
      "title": "Prerequisites",
      "type": "object"
    },
    "PreviewConfig": {
      "properties": {
        "start_command": {
          "default": "",
          "title": "Start Command",
          "type": "string",
          "description": "The dev-server start command"
        },
        "port": {
          "default": 3000,
          "title": "Port",
          "type": "integer",
          "description": "Dev server port"
        },
        "framework": {
          "default": "",
          "title": "Framework",
          "type": "string",
          "description": "Detected framework (Next.js, FastAPI, Django, etc.)"
        },
        "health_check": {
          "default": "",
          "title": "Health Check",
          "type": "string",
          "description": "Health endpoint path, e.g. /health"
        },
        "setup_steps": {
          "items": {
            "type": "string"
          },
          "title": "Setup Steps",
          "type": "array",
          "description": "Commands to run before start (install, migrate, seed)"
        },
        "uses_doppler": {
          "default": false,
          "title": "Uses Doppler",
          "type": "boolean"
        },
        "doppler_project": {
          "default": "",
          "title": "Doppler Project",
          "type": "string"
        },
        "doppler_config": {
          "default": "",
          "title": "Doppler Config",
          "type": "string"
        }
      },
      "title": "PreviewConfig",
      "type": "object",
      "description": "How to start the app locally for workspace preview"
    },
    "ReadinessScore": {
      "properties": {
        "score": {
          "default": 0,
          "title": "Score",
          "type": "integer",
          "description": "0-10 score indicating how well-equipped this repo is for autonomous AI development"
        },
        "rationale": {
          "default": "",
          "title": "Rationale",
          "type": "string",
          "description": "1-2 sentence explanation of the score"
        }
      },
      "title": "ReadinessScore",
      "type": "object",
      "description": "Agentic development readiness assessment (0-10)"
    },
    "ReadyCheck": {
      "properties": {
        "type": {
          "default": "",
          "title": "Type",
          "type": "string",
          "description": "http, tcp, log, delay"
        },
        "target": {
          "default": "",
          "title": "Target",
          "type": "string",
          "description": "e.g. localhost:5432 or http://localhost:8000/health"
        },
        "timeout": {
          "default": 30,
          "title": "Timeout",
          "type": "integer"
        }
      },
      "title": "ReadyCheck",
      "type": "object"
    },
    "TestCommand": {
      "properties": {
        "name": {
          "title": "Name",
          "type": "string",
          "description": "e.g. unit-tests, lint"
        },
        "run": {
          "title": "Run",
          "type": "string",
          "description": "Shell command to execute"
        },
        "expect": {
          "default": "exit_0",
          "title": "Expect",
          "type": "string",
          "description": "exit_0 = must exit 0"
        },
        "expect_value": {
          "default": "",
          "title": "Expect Value",
          "type": "string"
        },
        "needs": {
          "items": {
            "type": "string"
          },
          "title": "Needs",
          "type": "array",
          "description": "Component names that must be running"
        }
      },
      "required": [
        "name",
        "run"
      ],
      "title": "TestCommand",
      "type": "object"
    },
    "TestLevelConfig": {
      "properties": {
        "pre_commands": {
          "items": {
            "type": "string"
          },
          "title": "Pre Commands",
          "type": "array",
          "description": "Run before test commands (install, migrate, etc.)"
        },
        "commands": {
          "items": {
            "$ref": "#/$defs/TestCommand"
          },
          "title": "Commands",
          "type": "array"
        }
      },
      "title": "TestLevelConfig",
      "type": "object"
    }
  },
  "properties": {
    "test_level": {
      "default": 1,
      "title": "Test Level",
      "type": "integer",
      "description": "1 = L1 only, 2 = L1+L2"
    },
    "prerequisites": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/Prerequisite"
          },
          "type": "array"
        },
        {
          "$ref": "#/$defs/Prerequisites"
        }
      ],
      "title": "Prerequisites"
    },
    "components": {
      "items": {
        "$ref": "#/$defs/Component"
      },
      "title": "Components",
      "type": "array",
      "description": "Also accepts dict keyed by component name"
    },
    "levels": {
      "additionalProperties": {
        "$ref": "#/$defs/TestLevelConfig"
      },
      "title": "Levels",
      "type": "object",
      "description": "Keys: l1, l2"
    },
    "gaps": {
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "$ref": "#/$defs/Gap"
          }
        ]
      },
      "title": "Gaps",
      "type": "array"
    },
    "preview": {
      "$ref": "#/$defs/PreviewConfig"
    },
    "readiness": {
      "$ref": "#/$defs/ReadinessScore"
    }
  },
  "title": "TestManifest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://outbid.dev/schemas/test-manifest.json",
  "description": "Outbid test manifest \u2014 describes test infrastructure, components, and local preview config for a repository."
}
